# Copy to .env.local for local dev:
#   cp .env.example .env.local
#
# Nothing here is required for local dev — the app has sensible defaults.
# Set these for production (Vercel) or when you want custom behavior.

# --- Optional: Sanity CMS (mining wizard config)
# Defaults in code: project 32dlbkdi, dataset production
NEXT_PUBLIC_SANITY_PROJECT_ID=********
NEXT_PUBLIC_SANITY_DATASET=********

# --- Recommended for production deploy
# Used in sitemap, Open Graph, JSON-LD, and canonical URLs
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Optional: privacy-friendly analytics (Plausible)
# Leave unset to disable analytics script entirely
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# --- Optional: server-side progress backup API (/api/progress)
# Leave unset unless you want in-memory sync on the server
# QTC_PROGRESS_STORE=1
